# Eyebert — Quartus Pro project settings (key assignments)
# Pin location assignments (PIN_xx) are sourced from the Terasic DE25-Standard
# board baseline QSF shipped on the System CD. Import it before first compile:
#   source de25_standard_baseline.qsf

set_global_assignment -name FAMILY "Agilex 5"
set_global_assignment -name DEVICE A5ED013BB32AE4S
set_global_assignment -name TOP_LEVEL_ENTITY bert_top
set_global_assignment -name PROJECT_OUTPUT_DIRECTORY output_files
set_global_assignment -name NUM_PARALLEL_PROCESSORS ALL

set_global_assignment -name SYSTEMVERILOG_FILE ../rtl/prbs_gen.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../rtl/ber_counter.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../rtl/eye_sampler.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../rtl/axi_csr.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../rtl/ip_stubs.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../rtl/bert_top.sv
set_global_assignment -name SDC_FILE bert_top.sdc

# XTS-HSMC SMA channel 0 — transceiver pins via HSMC connector
set_instance_assignment -name IO_STANDARD "HIGH SPEED DIFFERENTIAL I/O" -to HSMC_TX_p[0]
set_instance_assignment -name IO_STANDARD "HIGH SPEED DIFFERENTIAL I/O" -to HSMC_TX_n[0]
set_instance_assignment -name IO_STANDARD "HIGH SPEED DIFFERENTIAL I/O" -to HSMC_RX_p[0]
set_instance_assignment -name IO_STANDARD "HIGH SPEED DIFFERENTIAL I/O" -to HSMC_RX_n[0]
set_instance_assignment -name IO_STANDARD LVDS -to HSMC_CLKOUT_p1
set_instance_assignment -name IO_STANDARD LVDS -to HSMC_CLKOUT_n1

# Map top-level ports to board signal names
set_instance_assignment -name VIRTUAL_PIN OFF -to tx_serial_p
set_location_assignment -to tx_serial_p "HSMC_TX_p[0]"
set_location_assignment -to tx_serial_n "HSMC_TX_n[0]"
set_location_assignment -to rx_serial_p "HSMC_RX_p[0]"
set_location_assignment -to rx_serial_n "HSMC_RX_n[0]"
set_location_assignment -to xcvr_refclk_p "HSMC_CLKOUT_p1"
set_location_assignment -to xcvr_refclk_n "HSMC_CLKOUT_n1"

set_global_assignment -name ENABLE_SIGNALTAP OFF
set_global_assignment -name USE_SIGNALTAP_FILE bert_debug.stp
